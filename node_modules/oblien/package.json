{
  "name": "oblien",
  "version": "2.0.2",
  "description": "Official TypeScript SDK for the Oblien Workspace API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "oblien": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./workspace": {
      "import": "./dist/workspace.js",
      "types": "./dist/workspace.d.ts"
    },
    "./runtime": {
      "import": "./dist/runtime.js",
      "types": "./dist/runtime.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "^5.4.0"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:oblien/sdk.git"
  },
  "homepage": "https://oblien.com/docs/sdk",
  "bugs": {
    "url": "https://github.com/oblien/sdk/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
